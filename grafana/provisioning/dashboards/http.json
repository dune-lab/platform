{
  "title": "HTTP Requests",
  "uid": "http-requests",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Requests",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{container=~\"platform-(odyssey|imperium|atreides|persona|janus)-1\"} | json | method=~\"GET|POST|PUT|DELETE|PATCH\" | line_format \"[{{.container}}] {{.method}} {{.url}} → {{.status}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "logs",
      "title": "5xx Errors",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{container=~\"platform-(odyssey|imperium|atreides|persona|janus)-1\"} | json | status >= 500 | line_format \"[{{.container}}] {{.method}} {{.url}} → {{.status}} | {{.error}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "4xx Errors",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{container=~\"platform-(odyssey|imperium|atreides|persona|janus)-1\"} | json | status >= 400 | status < 500 | line_format \"[{{.container}}] {{.method}} {{.url}} → {{.status}}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Slow Requests (sem health)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{container=~\"platform-(odyssey|imperium|atreides|persona|janus)-1\"} | json | url != \"/health\" | method=~\"GET|POST|PUT|DELETE|PATCH\" | line_format \"[{{.container}}] {{.method}} {{.url}} → {{.status}}\"",
          "refId": "A"
        }
      ]
    }
  ]
}
